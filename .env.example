# ============================================================
# Life OS – environment variables
# Copy to .env and fill in values before deploying.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Deployment targets (used by Kamal)
# ------------------------------------------------------------
GITHUB_USERNAME=your_github_username
KAMAL_REGISTRY_PASSWORD=            # GitHub personal access token with write:packages scope

# Production
DEPLOY_HOST=raspberrypi.local        # or IP address / hostname

# Staging (make deploy-staging)
STAGING_HOST=raspberrypi.local       # or IP address / hostname
STAGING_DOMAIN=lifeos-staging.kaizendevs.com

# Test deployment (make deploy-test)
TEST_HOST=raspberrypi.local          # or IP address / hostname
TEST_DOMAIN=lifeos-test.kaizendevs.com

# ------------------------------------------------------------
# PostgreSQL (used by Kamal accessory and app)
# ------------------------------------------------------------
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://backend:change_me@life-os-db/backend_production
STAGING_DATABASE_URL=postgres://backend:change_me@life-os-staging-db/backend_staging
TEST_DATABASE_URL=postgres://backend:change_me@life-os-test-db/backend_test_env

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
# Public hostname — used to build links in emails (e.g. password reset).
# Must match the domain your app is served from.
APP_HOST=lifeos.kaizendevs.com

# ------------------------------------------------------------
# Email (SMTP)
# Delivery uses SMTP2GO (primary) with SendPulse as automatic fallback.
# If neither provider is configured, emails are silently discarded (safe for local dev).
# SMTP_FROM and SMTP_DOMAIN are injected as clear env vars by Kamal per deploy target.
# ------------------------------------------------------------
SMTP_FROM=noreply@yourdomain.com     # from address on all outbound emails
SMTP_DOMAIN=yourdomain.com          # HELO domain (usually matches APP_HOST)

# SMTP2GO (primary) — app-us.smtp2go.com → Sending → SMTP Users
SMTP2GO_USERNAME=                    # e.g. yourdomain.com
SMTP2GO_PASSWORD=                    # from SMTP2GO SMTP user settings

# SendPulse (fallback) — sendpulse.com → Email → SMTP Settings
SENDPULSE_USERNAME=                  # e.g. you@yourdomain.com
SENDPULSE_PASSWORD=                  # from SendPulse SMTP settings

# ------------------------------------------------------------
# Rate limiting (Rack::Attack)
# Controls the password reset endpoint throttle.
# Applies per IP and per email address independently.
# ------------------------------------------------------------
PASSWORD_RESET_MAX_REQUESTS=5        # max attempts per window (default: 5)
PASSWORD_RESET_PERIOD_SECONDS=1200   # window size in seconds (default: 1200 = 20 min)

# ------------------------------------------------------------
# Rails secrets
# ------------------------------------------------------------
RAILS_MASTER_KEY=                    # contents of backend/config/master.key
DEVISE_JWT_SECRET_KEY=               # generate with: openssl rand -hex 64
