# Deployment target
GITHUB_USERNAME=your_github_username
DEPLOY_HOST=raspberrypi.local   # or IP address

# ── Production ────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://backend:change_me@life-os-db/backend_production

RAILS_MASTER_KEY=                # contents of backend/config/master.key
DEVISE_JWT_SECRET_KEY=           # generate with: openssl rand -hex 64

# ── Staging ───────────────────────────────────────────────────
POSTGRES_PASSWORD_STAGING=change_me
DATABASE_URL_STAGING=postgres://backend:change_me@life-os-staging-db/backend_staging

RAILS_MASTER_KEY_STAGING=        # generate with: cd backend && rails secret
DEVISE_JWT_SECRET_KEY_STAGING=   # generate with: openssl rand -hex 64

# ── Test env ──────────────────────────────────────────────────
POSTGRES_PASSWORD_TEST=change_me
DATABASE_URL_TEST=postgres://backend:change_me@life-os-test-db/backend_test_env

RAILS_MASTER_KEY_TEST=           # generate with: cd backend && rails secret
DEVISE_JWT_SECRET_KEY_TEST=      # generate with: openssl rand -hex 64

# ── GitHub Actions secrets (add these in repo Settings → Secrets) ──
# GH_USERNAME          → same as GITHUB_USERNAME
# DEPLOY_SSH_KEY       → private SSH key with access to the Pi (ssh-keygen -t ed25519)
# KAMAL_REGISTRY_PASSWORD → GHCR token (gh auth token)
