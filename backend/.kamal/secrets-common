# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Improve security by using a password manager. Never check config/master.key into git!
RAILS_MASTER_KEY=$(cat config/master.key)

# GHCR token pulled from gh CLI's keyring — no token files or env vars needed.
# Requires: gh auth login (one-time setup)
KAMAL_REGISTRY_PASSWORD=$(/opt/homebrew/bin/gh auth token)

# Both must be exported before deploying. Examples:
#   export POSTGRES_PASSWORD=mysecretpassword
#   export DATABASE_URL=postgres://backend:mysecretpassword@life-os-db/backend_production
#
# To switch to DigitalOcean managed DB, just change DATABASE_URL:
#   export DATABASE_URL=postgres://user:pass@managed-db-host/backend_production
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
DATABASE_URL=$DATABASE_URL
DEVISE_JWT_SECRET_KEY=$DEVISE_JWT_SECRET_KEY

# SMTP credentials — leave blank if using an unauthenticated relay or if SMTP_ADDRESS is not set.
SMTP_USERNAME=${SMTP_USERNAME:-}
SMTP_PASSWORD=${SMTP_PASSWORD:-}
