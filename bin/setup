#!/usr/bin/env bash
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo ""
echo -e "${BOLD}  Life OS — setup${NC}"
echo -e "${DIM}  ─────────────────────────────────────${NC}"
echo ""

# ── Prerequisites ──────────────────────────────────────────────────────────────
check() {
  local cmd=$1 label=$2 hint=$3
  if command -v "$cmd" &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} $label"
  else
    echo -e "  ${RED}✗${NC} $label — $hint"
    MISSING=1
  fi
}

MISSING=0
echo -e "${YELLOW}Checking prerequisites...${NC}\n"
check docker "Docker"   "install from https://docs.docker.com/get-docker"
check bun    "Bun"      "install from https://bun.sh"
check git    "Git"      "install from https://git-scm.com"
echo ""

if [[ $MISSING -eq 1 ]]; then
  echo -e "${RED}Install missing prerequisites and re-run bin/setup.${NC}\n"
  exit 1
fi

# ── .env ───────────────────────────────────────────────────────────────────────
echo -e "${YELLOW}Environment...${NC}\n"
if [[ ! -f "$ROOT/.env" ]]; then
  cp "$ROOT/.env.example" "$ROOT/.env"
  echo -e "  ${GREEN}✓${NC} .env created from .env.example"
  echo -e "  ${YELLOW}!${NC} Fill in .env before running the app"
else
  echo -e "  ${GREEN}✓${NC} .env already exists"
fi
echo ""

# ── Git hooks ──────────────────────────────────────────────────────────────────
echo -e "${YELLOW}Git hooks...${NC}\n"
git -C "$ROOT" config core.hooksPath .githooks
echo -e "  ${GREEN}✓${NC} Pre-commit hook activated"
echo ""

# ── Dependencies ───────────────────────────────────────────────────────────────
echo -e "${YELLOW}Installing dependencies...${NC}\n"
bun install --cwd "$ROOT" --silent
echo -e "  ${GREEN}✓${NC} Root packages installed"
bun install --cwd "$ROOT/frontend" --silent
echo -e "  ${GREEN}✓${NC} Frontend packages installed"
echo ""

# ── Docker images ──────────────────────────────────────────────────────────────
echo -e "${YELLOW}Pulling Docker images...${NC}\n"
docker compose -f "$ROOT/docker-compose.dev.yml" pull --quiet
echo -e "  ${GREEN}✓${NC} Docker images ready"
echo ""

# ── Done ───────────────────────────────────────────────────────────────────────
echo -e "${GREEN}${BOLD}  Setup complete!${NC}"
echo ""
echo -e "  Run ${BOLD}bun run menu${NC} to launch the interactive menu"
echo -e "  ${DIM}or: ./bin/dev${NC}"
echo ""
