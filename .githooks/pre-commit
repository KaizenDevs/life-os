#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# ── Frontend tests ────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}[1/2] Frontend tests (bun test)${NC}"
if ! bun test; then
  echo -e "\n${RED}✗ Frontend tests failed. Commit aborted.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Frontend tests passed${NC}"

# ── Backend tests ─────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}[2/2] Backend tests (RSpec)${NC}"

if ! docker compose -f "$(git rev-parse --show-toplevel)/docker-compose.yml" ps --services --filter status=running | grep -q "^web$"; then
  echo -e "${RED}✗ Docker 'web' container is not running. Start it with: docker compose up -d${NC}"
  exit 1
fi

if ! docker compose -f "$(git rev-parse --show-toplevel)/docker-compose.yml" exec -e RAILS_ENV=test web bundle exec rspec --format progress; then
  echo -e "\n${RED}✗ Backend tests failed. Commit aborted.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Backend tests passed${NC}"

echo -e "\n${GREEN}✓ All checks passed. Proceeding with commit.${NC}"
