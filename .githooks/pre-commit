#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ROOT="$(git rev-parse --show-toplevel)"
COMPOSE_FILE="${ROOT}/docker-compose.yml"

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# ── Frontend tests ────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}[1/2] Frontend tests (bun test)${NC}"
if ! bun test; then
  echo -e "\n${RED}✗ Frontend tests failed. Commit aborted.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Frontend tests passed${NC}"

# ── Backend tests ─────────────────────────────────────────────────────────────
echo -e "\n${YELLOW}[2/2] Backend tests (RSpec)${NC}"

if [ -n "${SKIP_BACKEND_PRECOMMIT:-}" ]; then
  echo -e "${YELLOW}⚠ Skipping RSpec (SKIP_BACKEND_PRECOMMIT is set). Run before pushing:${NC}"
  echo -e "${YELLOW}  docker compose exec -e RAILS_ENV=test web bundle exec rspec${NC}"
  echo -e "\n${GREEN}✓ Pre-commit finished (RSpec skipped). Proceeding with commit.${NC}"
  exit 0
fi

if ! command -v docker >/dev/null 2>&1; then
  echo -e "${RED}✗ docker CLI not found. Install Docker or skip once with SKIP_BACKEND_PRECOMMIT=1 git commit${NC}"
  exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo -e "${RED}✗ Docker daemon is not reachable. Start Docker, then: docker compose up -d${NC}"
  exit 1
fi

if [ ! -f "$COMPOSE_FILE" ]; then
  echo -e "${RED}✗ Missing ${COMPOSE_FILE}${NC}"
  exit 1
fi

if ! docker compose -f "$COMPOSE_FILE" ps --services --filter status=running 2>/dev/null | grep -q "^web$"; then
  echo -e "${RED}✗ Docker 'web' service is not running. Start it with: docker compose up -d${NC}"
  exit 1
fi

if ! docker compose -f "$COMPOSE_FILE" exec -T -e RAILS_ENV=test -e DATABASE_URL=postgres://postgres:postgres@db:5432/backend_test web bundle exec rspec --format progress; then
  echo -e "\n${RED}✗ Backend tests failed. Commit aborted.${NC}"
  exit 1
fi
echo -e "${GREEN}✓ Backend tests passed${NC}"

echo -e "\n${GREEN}✓ All checks passed. Proceeding with commit.${NC}"
